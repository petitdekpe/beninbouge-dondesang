{% extends 'base.html.twig' %}

{% block extra_css %}
body{background:#F4F2EA}
{% endblock %}

{% block body %}
<div style="min-height:100vh;font-family:'Manrope',sans-serif;color:#0E3F51">
  <header style="background:#0E3F51;padding:14px clamp(16px,5vw,28px);display:flex;align-items:center;flex-wrap:wrap;gap:16px;justify-content:space-between">
    <div style="display:flex;align-items:center;gap:22px;flex-wrap:wrap">
      <span style="font-weight:800;color:#fff;font-size:15px;letter-spacing:.3px">Bénin Bouge · Backoffice</span>
      <nav style="display:flex;gap:16px">
        <a href="{{ path('admin_messages') }}" style="color:{{ app.request.attributes.get('_route') starts with 'admin_messages' ? '#fff' : '#9fb3bc' }};text-decoration:none;font-weight:700;font-size:14px">Messages</a>
        <a href="{{ path('admin_donations') }}" style="color:{{ app.request.attributes.get('_route') starts with 'admin_donations' ? '#fff' : '#9fb3bc' }};text-decoration:none;font-weight:700;font-size:14px">Dons</a>
        <a href="{{ path('admin_sponsors') }}" style="color:{{ app.request.attributes.get('_route') starts with 'admin_sponsors' ? '#fff' : '#9fb3bc' }};text-decoration:none;font-weight:700;font-size:14px">Sponsors</a>
      </nav>
    </div>
    <a href="{{ path('admin_logout') }}" style="color:#fff;background:rgba(255,255,255,.12);padding:7px 14px;border-radius:999px;text-decoration:none;font-weight:700;font-size:13px">Déconnexion</a>
  </header>

  <main style="max-width:1100px;margin:0 auto;padding:clamp(20px,5vw,36px) clamp(16px,5vw,24px) 60px">
    {% for msg in app.flashes('admin_success') %}
      <div style="background:#e7f4ec;color:#295D3C;border:1px solid #bfe3cb;border-radius:10px;padding:12px 16px;margin-bottom:18px;font-weight:700">✓ {{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('admin_error') %}
      <div style="background:#fdeaea;color:#b91c1c;border:1px solid #f5c9c9;border-radius:10px;padding:12px 16px;margin-bottom:18px;font-weight:700">{{ msg }}</div>
    {% endfor %}
    {% block admin_body %}{% endblock %}
  </main>
</div>
{% endblock %}
