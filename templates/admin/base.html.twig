{% extends 'base.html.twig' %}

{% block extra_css %}
body{background:#F4F2EA}
@media (max-width:820px){
  .admin-sidebar{position:static !important;width:100% !important;height:auto !important;flex-direction:row !important;flex-wrap:wrap;padding:14px clamp(16px,4vw,24px) !important}
  .admin-sidebar-brand{width:100%}
  .admin-sidebar-nav{flex-direction:row !important;flex-wrap:wrap;gap:6px !important;width:auto !important}
  .admin-sidebar-logout{margin-left:auto !important;margin-top:0 !important}
  .admin-main{margin-left:0 !important}
}
{% endblock %}

{% block body %}
<div style="min-height:100vh;font-family:'Manrope',sans-serif;color:#0E3F51;display:flex">

  <aside class="admin-sidebar" style="position:fixed;top:0;left:0;width:240px;height:100vh;background:#0E3F51;padding:22px 18px;display:flex;flex-direction:column;gap:22px;overflow-y:auto;flex:none">
    <div class="admin-sidebar-brand" style="font-weight:800;color:#fff;font-size:15px;letter-spacing:.3px;line-height:1.3">Bénin Bouge<br><span style="color:#9fb3bc;font-weight:700;font-size:12.5px">Backoffice</span></div>

    <nav class="admin-sidebar-nav" style="display:flex;flex-direction:column;gap:4px">
      {% set links = [
        {route: 'admin_messages', label: 'Messages'},
        {route: 'admin_donations', label: 'Dons'},
        {route: 'admin_partners', label: 'Partenaires'},
        {route: 'admin_sponsors', label: 'Sponsors'},
        {route: 'admin_baobab_reservations', label: 'Réservations Baobab'},
        {route: 'admin_settings', label: 'Réglages'},
      ] %}
      {% for link in links %}
        {% set active = app.request.attributes.get('_route') starts with link.route %}
        <a href="{{ path(link.route) }}" style="color:{{ active ? '#fff' : '#9fb3bc' }};background:{{ active ? 'rgba(255,255,255,.1)' : 'transparent' }};text-decoration:none;font-weight:700;font-size:14px;padding:10px 12px;border-radius:9px">{{ link.label }}</a>
      {% endfor %}
    </nav>

    <a class="admin-sidebar-logout" href="{{ path('admin_logout') }}" style="margin-top:auto;color:#fff;background:rgba(255,255,255,.12);padding:9px 14px;border-radius:999px;text-decoration:none;font-weight:700;font-size:13px;text-align:center">Déconnexion</a>
  </aside>

  <main class="admin-main" style="flex:1;margin-left:240px;max-width:1100px;padding:clamp(20px,5vw,36px) clamp(16px,5vw,24px) 60px">
    {% for msg in app.flashes('admin_success') %}
      <div style="background:#e7f4ec;color:#295D3C;border:1px solid #bfe3cb;border-radius:10px;padding:12px 16px;margin-bottom:18px;font-weight:700">✓ {{ msg }}</div>
    {% endfor %}
    {% for msg in app.flashes('admin_error') %}
      <div style="background:#fdeaea;color:#b91c1c;border:1px solid #f5c9c9;border-radius:10px;padding:12px 16px;margin-bottom:18px;font-weight:700">{{ msg }}</div>
    {% endfor %}
    {% block admin_body %}{% endblock %}
  </main>
</div>
{% endblock %}
