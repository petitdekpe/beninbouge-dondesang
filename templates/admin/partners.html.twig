{% extends 'admin/base.html.twig' %}

{% block title %}Partenaires — Backoffice{% endblock %}

{% block admin_body %}
<h1 style="font-family:'Anton';font-size:clamp(24px,5vw,32px);text-transform:uppercase;color:#0E3F51;margin-bottom:6px">Gérer les partenaires</h1>
<p style="color:#6a6a60;font-size:14.5px;margin-bottom:24px">{{ partners|length }} partenaire(s). Catégories : <strong>Partenaire technique</strong> (carte visible sur le site avec rôle) · <strong>Partenaire</strong> (carte sans rôle obligatoire).</p>

<!-- add form -->
<div style="background:#fff;border:1px solid #ece4cf;border-radius:16px;padding:clamp(18px,4vw,24px);margin-bottom:30px">
  <h2 style="font-size:16px;font-weight:800;color:#0E3F51;margin-bottom:14px">Ajouter un partenaire</h2>
  <form method="post" action="{{ path('admin_partners_create') }}" enctype="multipart/form-data" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:12px;align-items:end">
    <input type="hidden" name="_token" value="{{ csrf_token('admin_partner_create') }}">
    <div>
      <label style="display:block;font-size:12px;font-weight:700;color:#6a6a60;margin-bottom:5px">Catégorie *</label>
      <select name="category" required style="width:100%;background:#F4F2EA;border:1px solid #e2ddcd;border-radius:9px;padding:10px 12px;font-size:14.5px;font-family:'Manrope'">
        <option value="technique">Partenaire technique</option>
        <option value="partenaire">Partenaire</option>
      </select>
    </div>
    <div>
      <label style="display:block;font-size:12px;font-weight:700;color:#6a6a60;margin-bottom:5px">Nom *</label>
      <input type="text" name="name" maxlength="120" required placeholder="Ex. ANTS" style="width:100%;background:#F4F2EA;border:1px solid #e2ddcd;border-radius:9px;padding:10px 12px;font-size:14.5px">
    </div>
    <div>
      <label style="display:block;font-size:12px;font-weight:700;color:#6a6a60;margin-bottom:5px">Rôle / description</label>
      <input type="text" name="role" maxlength="255" placeholder="Ex. Encadrement médical" style="width:100%;background:#F4F2EA;border:1px solid #e2ddcd;border-radius:9px;padding:10px 12px;font-size:14.5px">
    </div>
    <div>
      <label style="display:block;font-size:12px;font-weight:700;color:#6a6a60;margin-bottom:5px">Logo *</label>
      <input type="file" name="logo" accept="image/png,image/jpeg,image/webp,image/svg+xml" required style="width:100%;background:#F4F2EA;border:1px solid #e2ddcd;border-radius:9px;padding:9px 10px;font-size:13.5px">
    </div>
    <div>
      <label style="display:block;font-size:12px;font-weight:700;color:#6a6a60;margin-bottom:5px">Site web (optionnel)</label>
      <input type="text" name="website" placeholder="https://exemple.com" style="width:100%;background:#F4F2EA;border:1px solid #e2ddcd;border-radius:9px;padding:10px 12px;font-size:14.5px">
    </div>
    <div>
      <button type="submit" style="width:100%;background:#0E3F51;color:#fff;border:none;padding:11px;border-radius:9px;font-weight:800;font-size:14.5px;cursor:pointer">Ajouter</button>
    </div>
  </form>
</div>

<!-- list -->
{% set categories = [{'key': 'technique', 'label': 'Partenaires techniques'}, {'key': 'partenaire', 'label': 'Partenaires'}] %}
{% for cat in categories %}
  {% set catPartners = partners|filter(p => p.category == cat.key) %}
  {% if catPartners|length > 0 %}
    <div style="margin-bottom:28px">
      <div style="font-size:12px;font-weight:800;color:#fff;text-transform:uppercase;letter-spacing:1.4px;margin-bottom:10px">{{ cat.label }} ({{ catPartners|length }})</div>
      <div style="display:flex;flex-direction:column;gap:10px">
        {% for p in catPartners %}
          <div style="min-width:0;background:#fff;border:1px solid #ece4cf;border-radius:14px;padding:14px 18px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;justify-content:space-between">
            <div style="min-width:0;display:flex;align-items:center;gap:14px">
              <span style="flex:none;width:56px;height:56px;border-radius:10px;background:#F4F2EA;display:flex;align-items:center;justify-content:center;overflow:hidden">
                <img src="{{ asset('uploads/partners/' ~ p.logoFilename) }}" alt="{{ p.name }}" style="max-width:100%;max-height:100%;object-fit:contain">
              </span>
              <div style="min-width:0;overflow-wrap:break-word">
                <div style="font-weight:800;color:#0E3F51;font-size:15px">{{ p.name }}</div>
                {% if p.role %}
                  <div style="font-size:12.5px;color:#54544c;margin-top:2px">{{ p.role }}</div>
                {% endif %}
                <div style="font-size:12px;color:#fff;margin-top:2px">
                  {% if p.websiteUrl %}
                    <a href="{{ p.websiteUrl }}" target="_blank" rel="noopener" style="color:#3A8556">{{ p.websiteUrl }}</a>
                  {% else %}
                    Pas de site web
                  {% endif %}
                </div>
              </div>
            </div>
            <form method="post" action="{{ path('admin_partners_delete', {id: p.id}) }}" data-confirm="Supprimer ce partenaire ?">
              <input type="hidden" name="_token" value="{{ csrf_token('admin_partner_' ~ p.id) }}">
              <button type="submit" style="background:#fdeaea;color:#b91c1c;border:1px solid #f5c9c9;padding:7px 13px;border-radius:999px;font-weight:700;font-size:12.5px;cursor:pointer">Supprimer</button>
            </form>
          </div>
        {% endfor %}
      </div>
    </div>
  {% endif %}
{% endfor %}

{% if partners|length == 0 %}
  <p style="color:#fff;text-align:center;padding:30px 0">Aucun partenaire pour le moment.</p>
{% endif %}
{% endblock %}

{% block javascripts %}
<script>
document.querySelectorAll('form[data-confirm]').forEach(function (form) {
  form.addEventListener('submit', function (e) {
    if (!window.confirm(form.getAttribute('data-confirm'))) e.preventDefault();
  });
});
</script>
{% endblock %}
