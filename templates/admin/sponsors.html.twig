{% extends 'admin/base.html.twig' %}

{% block title %}Sponsors — Backoffice{% endblock %}

{% block admin_body %}
<h1 style="font-family:'Anton';font-size:clamp(24px,5vw,32px);text-transform:uppercase;color:#0E3F51;margin-bottom:6px">Gérer les sponsors</h1>
<p style="color:#6a6a60;font-size:14.5px;margin-bottom:24px">{{ sponsors|length }} sponsor(s). Le logo seul est affiché publiquement ; le site web (si renseigné) s'ouvre au clic sur le logo.</p>

<!-- add form -->
<div style="background:#fff;border:1px solid #ece4cf;border-radius:16px;padding:clamp(18px,4vw,24px);margin-bottom:30px">
  <h2 style="font-size:16px;font-weight:800;color:#0E3F51;margin-bottom:14px">Ajouter un sponsor</h2>
  <form method="post" action="{{ path('admin_sponsors_create') }}" enctype="multipart/form-data" style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));gap:12px;align-items:end">
    <input type="hidden" name="_token" value="{{ csrf_token('admin_sponsor_create') }}">
    <div>
      <label style="display:block;font-size:12px;font-weight:700;color:#6a6a60;margin-bottom:5px">Nom *</label>
      <input type="text" name="name" maxlength="120" required placeholder="Ex. Total Énergies" style="width:100%;background:#F4F2EA;border:1px solid #e2ddcd;border-radius:9px;padding:10px 12px;font-size:14.5px">
    </div>
    <div>
      <label style="display:block;font-size:12px;font-weight:700;color:#6a6a60;margin-bottom:5px">Logo *</label>
      <input type="file" name="logo" accept="image/png,image/jpeg,image/webp,image/svg+xml" required style="width:100%;background:#F4F2EA;border:1px solid #e2ddcd;border-radius:9px;padding:9px 10px;font-size:13.5px">
    </div>
    <div>
      <label style="display:block;font-size:12px;font-weight:700;color:#6a6a60;margin-bottom:5px">Site web (optionnel)</label>
      <input type="text" name="website" placeholder="https://exemple.com" style="width:100%;background:#F4F2EA;border:1px solid #e2ddcd;border-radius:9px;padding:10px 12px;font-size:14.5px">
    </div>
    <div>
      <button type="submit" style="width:100%;background:#3A8556;color:#fff;border:none;padding:11px;border-radius:9px;font-weight:800;font-size:14.5px;cursor:pointer">Ajouter</button>
    </div>
  </form>
</div>

<!-- list -->
<div style="display:flex;flex-direction:column;gap:10px">
  {% for s in sponsors %}
    <div style="min-width:0;background:#fff;border:1px solid #ece4cf;border-radius:14px;padding:14px 18px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;justify-content:space-between">
      <div style="min-width:0;display:flex;align-items:center;gap:14px">
        <span style="flex:none;width:56px;height:56px;border-radius:10px;background:#F4F2EA;display:flex;align-items:center;justify-content:center;overflow:hidden">
          <img src="{{ asset('uploads/sponsors/' ~ s.logoFilename) }}" alt="{{ s.name }}" style="max-width:100%;max-height:100%;object-fit:contain">
        </span>
        <div style="min-width:0;overflow-wrap:break-word">
          <div style="font-weight:800;color:#0E3F51;font-size:15px">{{ s.name }}</div>
          <div style="font-size:12.5px;color:#9a9a8f;margin-top:2px">{% if s.websiteUrl %}<a href="{{ s.websiteUrl }}" target="_blank" rel="noopener" style="color:#3A8556">{{ s.websiteUrl }}</a>{% else %}Pas de site web{% endif %}</div>
        </div>
      </div>
      <form method="post" action="{{ path('admin_sponsors_delete', {id: s.id}) }}" data-confirm="Supprimer ce sponsor ?">
        <input type="hidden" name="_token" value="{{ csrf_token('admin_sponsor_' ~ s.id) }}">
        <button type="submit" style="background:#fdeaea;color:#b91c1c;border:1px solid #f5c9c9;padding:7px 13px;border-radius:999px;font-weight:700;font-size:12.5px;cursor:pointer">Supprimer</button>
      </form>
    </div>
  {% else %}
    <p style="color:#9a9a8f;text-align:center;padding:30px 0">Aucun sponsor pour le moment.</p>
  {% endfor %}
</div>
{% endblock %}

{% block javascripts %}
<script>
document.querySelectorAll('form[data-confirm]').forEach(function (form) {
  form.addEventListener('submit', function (e) {
    if (!window.confirm(form.getAttribute('data-confirm'))) e.preventDefault();
  });
});
</script>
{% endblock %}
