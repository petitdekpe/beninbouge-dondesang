<!DOCTYPE html>
<html lang="{{ lang|default('fr') }}">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{% block title %}Bénin Bouge{% endblock %}</title>

<link rel="icon" type="image/png" href="{{ asset('assets/favicon/favicon-96x96.png') }}" sizes="96x96">
<link rel="icon" type="image/svg+xml" href="{{ asset('assets/favicon/favicon.svg') }}">
<link rel="shortcut icon" href="{{ asset('assets/favicon/favicon.ico') }}">
<link rel="apple-touch-icon" sizes="180x180" href="{{ asset('assets/favicon/apple-touch-icon.png') }}">
<link rel="manifest" href="{{ asset('assets/favicon/site.webmanifest') }}">
<meta name="theme-color" content="#14160F">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Anton&family=Archivo:wght@500;600;700;800;900&family=Manrope:wght@400;500;600;700;800&display=swap" rel="stylesheet">
<style>
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:#14160F;font-family:'Manrope',system-ui,sans-serif;-webkit-font-smoothing:antialiased}
@keyframes bbFloat{0%,100%{transform:translateY(0) rotate(var(--r,0deg))}50%{transform:translateY(-10px) rotate(var(--r,0deg))}}
@keyframes bbSpark{0%,100%{opacity:.35;transform:scale(.85)}50%{opacity:1;transform:scale(1.15)}}
@keyframes bbPulse{0%,100%{transform:scale(1)}50%{transform:scale(1.07)}}
@keyframes bbRise{from{opacity:0;transform:translateY(16px)}to{opacity:1;transform:translateY(0)}}
@keyframes bbConf{0%{transform:translateY(-20vh) rotate(0deg);opacity:0}10%{opacity:1}100%{transform:translateY(112vh) rotate(720deg);opacity:1}}
@keyframes bbPop{0%{transform:scale(0)}60%{transform:scale(1.12)}100%{transform:scale(1)}}
@keyframes bbDraw{to{stroke-dashoffset:0}}
@keyframes bbMarquee{from{transform:translateX(0)}to{transform:translateX(-50%)}}
@keyframes bbDriveBy{0%{transform:translateX(-30vw) scaleX(-1) translateY(0)}50%{transform:translateX(50vw) scaleX(-1) translateY(-3px)}100%{transform:translateX(130vw) scaleX(-1) translateY(0)}}
@keyframes bbExitLeft{0%{transform:translateX(0)}100%{transform:translateX(-160vw)}}
@keyframes bbEnterFromRight{0%{transform:translateX(160vw)}100%{transform:translateX(0)}}
input::placeholder,textarea::placeholder{color:#fff}
{% block extra_css %}{% endblock %}
</style>
{% block stylesheets %}{% endblock %}
</head>
<body class="{% block body_class %}{% endblock %}">
{% block body %}{% endblock %}
{% block javascripts %}{% endblock %}
<script>
(function () {
  var heart = [
    ' ██   ██ ',
    '█████████',
    '█████████',
    '█████████',
    ' ███████ ',
    '  █████  ',
    '   ███   ',
    '    █    '
  ].join('\n');

  console.log('%c' + heart, 'color:#008651;font-weight:900;font-family:monospace;line-height:1.1;');
  console.log('%cChaque ligne de code compte, comme chaque geste pour le Bénin.', 'font-size:16px;font-weight:800;color:#0E3F51;');
  console.log('%cEnvie de coder pour la cause ? %ccontact@beninbouge.com', 'font-size:13px;color:#55584e;', 'font-size:13px;font-weight:800;color:#3A8556;');
  console.log('%cBénin Bouge — le média du Bénin qui bouge', 'font-size:11px;color:#9a9a90;letter-spacing:1px;');
})();
</script>
<script>
(function () {
  var dropColors = ['#008651', '#3A8556', '#295D3C', '#6BA480'];

  // Shared red-confetti rain, reused by the Konami code and the
  // mobile shake easter eggs so both effects stay visually identical.
  window.bbSpawnBloodRain = function (count) {
    var layer = document.createElement('div');
    layer.style.cssText = 'position:fixed;inset:0;z-index:9999;pointer-events:none;overflow:hidden';
    document.body.appendChild(layer);

    for (var i = 0; i < (count || 60); i++) {
      var piece = document.createElement('div');
      var isDrop = Math.random() > 0.4;
      var size = 8 + Math.random() * 10;
      var duration = 2.4 + Math.random() * 2;
      var delay = Math.random() * 0.8;
      piece.style.cssText =
        'position:absolute;top:-6vh;left:' + (Math.random() * 100) + 'vw;' +
        'width:' + size + 'px;height:' + size + 'px;' +
        'background:' + dropColors[(Math.random() * dropColors.length) | 0] + ';' +
        (isDrop ? 'border-radius:50% 50% 50% 0;' : 'border-radius:50%;') +
        'opacity:0;box-shadow:0 2px 6px rgba(0,0,0,.15);' +
        'animation:bbConf ' + duration + 's ease-in ' + delay + 's forwards;';
      layer.appendChild(piece);
    }

    setTimeout(function () { layer.remove(); }, 5200);
  };

  window.bbShowToast = function (text, duration) {
    var toast = document.createElement('div');
    toast.textContent = text;
    toast.style.cssText =
      'position:fixed;top:90px;left:50%;transform:translateX(-50%);z-index:10000;' +
      'background:#0E3F51;color:#fff;padding:16px 28px;border-radius:999px;text-align:center;' +
      'font-family:Manrope,sans-serif;font-weight:800;font-size:15px;white-space:nowrap;' +
      'box-shadow:0 12px 30px rgba(0,0,0,.35);animation:bbRise .4s ease both;transition:opacity .5s ease';
    document.body.appendChild(toast);
    setTimeout(function () {
      toast.style.opacity = '0';
      setTimeout(function () { toast.remove(); }, 500);
    }, duration || 3200);
  };
})();
</script>
<script>
(function () {
  var sequence = ['ArrowUp', 'ArrowUp', 'ArrowDown', 'ArrowDown', 'ArrowLeft', 'ArrowRight', 'ArrowLeft', 'ArrowRight', 'b', 'a'];
  var progress = 0;
  var running = false;

  function trigger() {
    if (running) return;
    running = true;
    window.bbSpawnBloodRain();
    window.bbShowToast('🎉 Vous avez trouvé le easter egg des 2 ans !');
    setTimeout(function () { running = false; }, 4000);
  }

  document.addEventListener('keydown', function (e) {
    var key = e.key.length === 1 ? e.key.toLowerCase() : e.key;
    var expected = sequence[progress];
    if (key === expected) {
      progress++;
      if (progress === sequence.length) {
        progress = 0;
        trigger();
      }
    } else {
      progress = (key === sequence[0]) ? 1 : 0;
    }
  });
})();
</script>
<script>
(function () {
  if (typeof window.DeviceMotionEvent === 'undefined') return;

  var THRESHOLD = 18;
  var COOLDOWN = 3000;
  var lastX = null, lastY = null, lastZ = null;
  var lastShake = 0;
  var running = false;

  function trigger() {
    if (running) return;
    running = true;
    window.bbSpawnBloodRain();
    window.bbShowToast('📱 Secoué avec amour ! Merci de nous suivre 💚');
    setTimeout(function () { running = false; }, 4000);
  }

  function onMotion(e) {
    var acc = e.accelerationIncludingGravity || e.acceleration;
    if (!acc || acc.x === null) return;

    var x = acc.x || 0, y = acc.y || 0, z = acc.z || 0;
    if (lastX !== null) {
      var delta = Math.abs(x - lastX) + Math.abs(y - lastY) + Math.abs(z - lastZ);
      var now = Date.now();
      if (delta > THRESHOLD && now - lastShake > COOLDOWN) {
        lastShake = now;
        trigger();
      }
    }
    lastX = x; lastY = y; lastZ = z;
  }

  function enable() {
    window.addEventListener('devicemotion', onMotion);
  }

  // iOS 13+ gates motion sensors behind an explicit permission prompt that
  // must be requested from within a user gesture — a first tap anywhere.
  if (typeof window.DeviceMotionEvent.requestPermission === 'function') {
    document.addEventListener('touchend', function requestOnce() {
      document.removeEventListener('touchend', requestOnce);
      window.DeviceMotionEvent.requestPermission().then(function (state) {
        if (state === 'granted') enable();
      }).catch(function () {});
    }, { once: true });
  } else {
    enable();
  }
})();
</script>
<script>
(function () {
  var originalTitle = document.title;
  var awayTitle = 'Merci d'avoir sauver des vies 🩸';

  document.addEventListener('visibilitychange', function () {
    document.title = document.hidden ? awayTitle : originalTitle;
  });
})();
</script>
</body>
</html>
