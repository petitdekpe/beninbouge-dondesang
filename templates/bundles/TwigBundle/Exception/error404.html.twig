{% extends 'base.html.twig' %}

{% block title %}Page introuvable — Bénin Bouge{% endblock %}

{% block extra_css %}
.err-drop{animation:bbFloat 5s ease-in-out infinite}
{% endblock %}

{% block body %}
<div style="background:#FBFAF5;color:#14160F;font-family:'Manrope',sans-serif;overflow-x:hidden;min-height:100vh;display:flex;flex-direction:column">

  <header style="padding:20px clamp(16px,4vw,24px)">
    <a href="{{ path('landing') }}" style="display:inline-flex;align-items:center;gap:8px;text-decoration:none">
      <img src="{{ asset('assets/mark-coureur.png') }}" alt="Bénin Bouge" style="height:30px;width:auto;display:block"/>
    </a>
  </header>

  <main style="flex:1;display:flex;align-items:center;justify-content:center;padding:24px clamp(16px,5vw,24px) 60px">
    <div style="max-width:560px;text-align:center">

      <div class="err-drop" style="width:64px;height:64px;margin:0 auto 20px;position:relative">
        <div style="position:absolute;inset:0;background:#008651;border-radius:50% 50% 50% 0;transform:rotate(45deg);box-shadow:0 12px 26px rgba(0,134,81,.3)"></div>
        <div style="position:absolute;top:38%;left:38%;width:26%;height:26%;background:rgba(255,255,255,.35);border-radius:50%;transform:rotate(45deg)"></div>
      </div>

      <div style="font-family:'Anton',sans-serif;font-size:clamp(64px,14vw,110px);line-height:1;color:#0E3F51">404</div>

      <h1 style="font-family:'Anton',sans-serif;text-transform:uppercase;font-size:clamp(22px,4vw,30px);margin-top:12px;color:#0E3F51">Cette page s'est perdue</h1>

      <p style="font-size:clamp(15px,2.2vw,17px);line-height:1.65;color:#55584e;margin-top:16px">
        …comme une occasion jamais saisie. Le lien que vous avez suivi n'existe pas ou plus —
        mais vous, vous pouvez encore faire la différence.
      </p>

      <div style="display:flex;flex-wrap:wrap;gap:14px;justify-content:center;margin-top:32px">
        <a href="{{ path('landing') }}#don" style="background:#008651;color:#fff;text-decoration:none;padding:16px 30px;border-radius:999px;font-weight:800;font-size:16px;display:inline-flex;align-items:center;gap:9px;box-shadow:0 12px 30px rgba(0,134,81,.35)">
          <span style="font-size:17px">♥</span> Faire un don maintenant
        </a>
        <a href="{{ path('landing') }}" style="background:transparent;color:#0E3F51;border:1.5px solid rgba(14,63,81,.3);text-decoration:none;padding:16px 28px;border-radius:999px;font-weight:700;font-size:16px;display:inline-flex;align-items:center;gap:8px">
          Retour à l'accueil
        </a>
      </div>

    </div>
  </main>
</div>
{% endblock %}
