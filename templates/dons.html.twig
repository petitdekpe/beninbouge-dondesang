{% extends 'base.html.twig' %}

{% block title %}{{ t.tracking.title }} — Bénin Bouge{% endblock %}

{% block extra_css %}
body{background:#FBF7EC}
@media (max-width:760px){
  .bb-nav{display:none !important}
}
{% endblock %}

{% block body %}
<div style="min-height:100vh;background:#FBF7EC;color:#0E3F51;font-family:'Manrope',sans-serif">

  <!-- header -->
  <header style="position:sticky;top:0;z-index:40;background:rgba(14, 63, 81, 0.96);backdrop-filter:blur(10px);border-bottom:1px solid rgba(14,63,81,.45)">
    <div class="bb-header-row" style="max-width:1200px;margin:0 auto;padding:14px clamp(16px,4vw,24px);display:flex;align-items:center;flex-wrap:wrap;gap:clamp(10px,2vw,20px)">
      <a href="{{ path('landing', {lang: lang}) }}#top" style="display:flex;align-items:center;gap:9px;text-decoration:none;flex:none">
        <img src="{{ asset('assets/mark-coureur.png') }}" alt="Bénin Bouge" style="height:clamp(30px,6vw,42px);width:auto;display:block"/>
        <img src="{{ asset('assets/logo-sdvs-blanc.png') }}" alt="Sang Donné, Vies Sauvées" style="height:clamp(36px,7vw,50px);width:auto;display:block"/>
      </a>
      <nav class="bb-nav" style="display:flex;gap:26px;margin-left:18px;flex:1">
        <a href="{{ path('landing', {lang: lang}) }}#campagne" style="color:#EFEEE6;text-decoration:none;font-weight:600;font-size:14.5px;letter-spacing:.2px">{{ t.nav.campaign }}</a>
        <a href="{{ path('landing', {lang: lang}) }}#partenaires" style="color:#EFEEE6;text-decoration:none;font-weight:600;font-size:14.5px;letter-spacing:.2px">{{ t.nav.partners }}</a>
        <a href="{{ path('landing', {lang: lang}) }}#infos" style="color:#EFEEE6;text-decoration:none;font-weight:600;font-size:14.5px;letter-spacing:.2px">{{ t.nav.info }}</a>
        <a href="{{ path('donations_track', {lang: lang}) }}" style="color:#EFEEE6;text-decoration:none;font-weight:600;font-size:14.5px;letter-spacing:.2px">{{ t.tracking.title }}</a>
        <a href="{{ path('messages_list', {lang: lang}) }}" style="color:#EFEEE6;text-decoration:none;font-weight:600;font-size:14.5px;letter-spacing:.2px">Vos messages</a>
      </nav>
      <div style="display:flex;align-items:center;gap:clamp(8px,2vw,14px);flex:none;margin-left:auto">
        <div style="display:flex;border:1px solid rgba(255,255,255,.22);border-radius:999px;overflow:hidden">
          <a href="?lang=fr" style="display:inline-block;background:{{ lang == 'fr' ? '#fff' : 'transparent' }};color:{{ lang == 'fr' ? '#295D3C' : '#EFEEE6' }};padding:6px 13px;font-family:Manrope;font-weight:800;font-size:13px;text-decoration:none">FR</a>
          <a href="?lang=en" style="display:inline-block;background:{{ lang == 'en' ? '#fff' : 'transparent' }};color:{{ lang == 'en' ? '#295D3C' : '#EFEEE6' }};padding:6px 13px;font-family:Manrope;font-weight:800;font-size:13px;text-decoration:none">EN</a>
        </div>
        <a href="{{ path('landing', {lang: lang}) }}#don" style="background:#C83E34;color:#fff;text-decoration:none;padding:clamp(9px,2vw,11px) clamp(14px,4vw,20px);border-radius:999px;font-family:'Manrope';font-weight:800;font-size:clamp(13px,2vw,14.5px);display:flex;align-items:center;gap:8px;box-shadow:0 6px 18px rgba(225,37,27,.35);white-space:nowrap">
          <span style="font-size:15px">♥</span>{{ t.nav.donate }}
        </a>
      </div>
    </div>
  </header>

  <!-- main -->
  <main style="max-width:900px;margin:0 auto;padding:clamp(10px,4vw,20px) clamp(16px,5vw,24px) clamp(60px,9vw,90px)">

    <div style="text-align:center;margin:clamp(20px,5vw,32px) 0 clamp(30px,6vw,40px)">
      <div style="color:#3A8556;font-weight:800;font-size:13px;letter-spacing:2px;text-transform:uppercase">{{ t.tracking.kicker }}</div>
      <h1 style="font-family:'Anton';font-size:clamp(28px,6vw,44px);margin:12px 0 0;text-transform:uppercase;color:#0E3F51">{{ t.tracking.title }}</h1>
      <p style="font-size:clamp(15px,2.2vw,16.5px);line-height:1.6;color:#55584e;margin:14px auto 0;max-width:560px">{{ t.tracking.lead }}</p>
    </div>

    <!-- total card -->
    <div style="background:#0E3F51;border-radius:20px;padding:clamp(26px,6vw,38px);text-align:center;box-shadow:0 18px 40px rgba(14,63,81,.25)">
      <div style="color:#9fb3bc;font-weight:700;font-size:12.5px;letter-spacing:1.4px;text-transform:uppercase">{{ t.tracking.totalLabel }}</div>
      <div style="font-family:'Anton';font-size:clamp(40px,11vw,72px);color:#fff;line-height:1;margin-top:10px">{{ total|number_format(0, ',', ' ') }} <span style="font-size:clamp(18px,3vw,28px);color:#89B69A">FCFA</span></div>
      <div style="margin-top:10px;color:#CFD9DD;font-weight:700;font-size:14px">{{ count }} {{ t.tracking.countSuffix }}</div>
    </div>

    <!-- list -->
    <div style="margin-top:clamp(34px,6vw,48px)">
      <h2 style="font-family:'Anton';font-size:clamp(20px,4vw,26px);text-transform:uppercase;color:#0E3F51;margin-bottom:18px">{{ t.tracking.listTitle }}</h2>

      <div style="display:flex;flex-direction:column;gap:10px">
        {% for d in donations %}
          <div style="min-width:0;background:#fff;border:1px solid #ece4cf;border-radius:14px;padding:16px 18px;display:flex;align-items:center;gap:14px;flex-wrap:wrap;justify-content:space-between">
            <div style="min-width:0;display:flex;align-items:center;gap:12px">
              <span style="flex:none;width:38px;height:38px;border-radius:50%;background:rgba(58,133,86,.14);color:#3A8556;display:flex;align-items:center;justify-content:center;font-size:16px">♥</span>
              <div style="min-width:0;overflow-wrap:break-word">
                <div style="font-weight:800;color:#0E3F51;font-size:15px">{{ d.anonymous or not d.donorName ? t.tracking.anonymous : d.donorName }}</div>
                <div style="font-size:12.5px;color:#fff;margin-top:2px">{{ d.confirmedAt ? d.confirmedAt|date('d/m/Y H:i') : d.createdAt|date('d/m/Y H:i') }}</div>
              </div>
            </div>
            <div style="font-family:'Anton';font-size:clamp(17px,3vw,21px);color:#C83E34;flex:none">{{ d.amount|number_format(0, ',', ' ') }} <span style="font-size:13px;color:#0E3F51">FCFA</span></div>
          </div>
        {% else %}
          <p style="text-align:center;color:#fff;padding:30px 0">{{ t.tracking.empty }}</p>
        {% endfor %}
      </div>
    </div>

    <div style="text-align:center;margin-top:clamp(36px,6vw,48px);display:flex;flex-wrap:wrap;gap:14px;justify-content:center">
      <a href="{{ path('landing', {lang: lang}) }}" style="display:inline-flex;align-items:center;gap:8px;color:#0E3F51;text-decoration:none;font-weight:800;font-size:15px;border-bottom:2px solid #3A8556;padding-bottom:2px">{{ t.tracking.back }}</a>
      <a href="{{ path('landing', {lang: lang}) }}#don" style="display:inline-flex;align-items:center;gap:8px;background:#C83E34;color:#fff;text-decoration:none;font-weight:800;font-size:15px;padding:10px 20px;border-radius:999px">{{ t.tracking.cta }}</a>
    </div>
  </main>
</div>
{% endblock %}
