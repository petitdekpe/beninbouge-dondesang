{% extends 'base.html.twig' %}

{% block title %}Bénin Bouge — Sang Donné, Vies Sauvées{% endblock %}

{% block extra_css %}
@media (max-width:760px){
  .bb-nav{display:none !important}
}
@media (max-width:480px){
  .bb-header-row{gap:10px !important}
}
#voeux input::placeholder,#voeux textarea::placeholder{color:#14160F;opacity:.7}
{% endblock %}

{% block body %}
<div style="background:#FBFAF5;color:#14160F;font-family:'Manrope',sans-serif;overflow-x:hidden">

  <!-- ============ HEADER ============ -->
  <header style="position:sticky;top:0;z-index:40;background:rgba(14, 63, 81, 0.96);backdrop-filter:blur(10px);border-bottom:1px solid rgba(14,63,81,.45)">
    <div class="bb-header-row" style="max-width:1200px;margin:0 auto;padding:14px clamp(16px,4vw,24px);display:flex;align-items:center;flex-wrap:wrap;gap:clamp(10px,2vw,20px)">
      <a href="#top" style="display:flex;align-items:center;gap:9px;text-decoration:none;flex:none">
        <img src="{{ asset('assets/mark-coureur.png') }}" alt="Bénin Bouge" style="height:clamp(30px,6vw,42px);width:auto;display:block"/>
        <img src="{{ asset('assets/logo-sdvs-blanc.png') }}" alt="Sang Donné, Vies Sauvées" style="height:clamp(36px,7vw,50px);width:auto;display:block"/>
      </a>
      <nav class="bb-nav" style="display:flex;gap:26px;margin-left:18px;flex:1">
        <a href="#campagne" style="color:#EFEEE6;text-decoration:none;font-weight:600;font-size:14.5px;letter-spacing:.2px">{{ t.nav.campaign }}</a>
        <a href="#partenaires" style="color:#EFEEE6;text-decoration:none;font-weight:600;font-size:14.5px;letter-spacing:.2px">{{ t.nav.partners }}</a>
        <a href="#infos" style="color:#EFEEE6;text-decoration:none;font-weight:600;font-size:14.5px;letter-spacing:.2px">{{ t.nav.info }}</a>
        <a href="{{ path('donations_track', {lang: lang}) }}" style="color:#EFEEE6;text-decoration:none;font-weight:600;font-size:14.5px;letter-spacing:.2px">{{ t.tracking.title }}</a>
        <a href="{{ path('messages_list', {lang: lang}) }}" style="color:#EFEEE6;text-decoration:none;font-weight:600;font-size:14.5px;letter-spacing:.2px">Vos messages</a>
      </nav>
      <div style="display:flex;align-items:center;gap:clamp(8px,2vw,14px);flex:none;margin-left:auto">
        <div style="display:flex;border:1px solid rgba(255,255,255,.22);border-radius:999px;overflow:hidden">
          <a href="?lang=fr" style="display:inline-block;background:{{ lang == 'fr' ? '#fff' : 'transparent' }};color:{{ lang == 'fr' ? '#295D3C' : '#EFEEE6' }};padding:6px 13px;font-family:Manrope;font-weight:800;font-size:13px;text-decoration:none">FR</a>
          <a href="?lang=en" style="display:inline-block;background:{{ lang == 'en' ? '#fff' : 'transparent' }};color:{{ lang == 'en' ? '#295D3C' : '#EFEEE6' }};padding:6px 13px;font-family:Manrope;font-weight:800;font-size:13px;text-decoration:none">EN</a>
        </div>
        <button data-open-modal style="background:#C83E34;color:#fff;border:none;padding:clamp(9px,2vw,11px) clamp(14px,4vw,20px);border-radius:999px;font-family:'Manrope';font-weight:800;font-size:clamp(13px,2vw,14.5px);cursor:pointer;display:flex;align-items:center;gap:8px;box-shadow:0 6px 18px rgba(225,37,27,.35);white-space:nowrap">
          <span style="font-size:15px">♥</span>{{ t.nav.donate }}
        </button>
      </div>
    </div>
  </header>

  <!-- ============ HERO ============ -->
  <section id="top" style="position:relative;background:#FBF7EC;color:#0E3F51;overflow:hidden">
    <div style="position:absolute;top:8%;left:6%;width:14px;height:14px;background:#0E3F51;border-radius:50%;animation:bbSpark 3.5s ease-in-out infinite"></div>
    <div style="position:absolute;top:22%;right:10%;width:42px;height:6px;background:#3A8556;border-radius:4px;transform:rotate(-24deg);animation:bbFloat 6s ease-in-out infinite;--r:-24deg"></div>
    <div style="position:absolute;bottom:18%;left:11%;width:34px;height:6px;background:#0E3F51;border-radius:4px;transform:rotate(18deg);animation:bbFloat 7s ease-in-out infinite;--r:18deg"></div>
    <div style="position:absolute;top:14%;right:30%;font-size:26px;color:#6BA480;animation:bbSpark 4s ease-in-out infinite">✦</div>
    <div style="position:absolute;bottom:26%;right:18%;width:10px;height:10px;background:#C83E34;border-radius:50%;animation:bbSpark 3s ease-in-out infinite"></div>
    <div style="position:absolute;inset:0;background:radial-gradient(900px 480px at 78% 28%, rgba(58,133,86,.13), transparent 60%),radial-gradient(700px 420px at 12% 80%, rgba(14,63,81,.14), transparent 60%)"></div>

    <div style="position:relative;max-width:1200px;margin:0 auto;padding:clamp(40px,8vw,64px) clamp(16px,5vw,24px) clamp(48px,9vw,76px);display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:clamp(28px,5vw,48px);align-items:center">
      <div>
        <!--div style="display:inline-flex;align-items:center;gap:9px;background:#3A8556;border:1px solid #3A8556;color:#fff;padding:7px 15px;border-radius:999px;font-weight:800;font-size:13px;letter-spacing:1.5px;text-transform:uppercase">
          <span style="width:7px;height:7px;background:#fff;border-radius:50%;display:inline-block"></span>{{ t.hero.badge }}
        </div-->
        <h1 style="font-family:'Anton',sans-serif;font-weight:400;font-size:clamp(38px,8vw,72px);line-height:1.0;margin:22px 0 0;letter-spacing:.5px;text-transform:uppercase">
          <span style="display:block;color:#0E3F51">{{ t.hero.t1 }}</span>
          <span style="display:block;color:#0E3F51">{{ t.hero.t2 }}</span>
          <span style="display:block;color:#3A8556">{{ t.hero.t3 }}</span>
        </h1>
        <p style="font-size:clamp(15px,2.4vw,18px);line-height:1.6;color:#55584e;max-width:520px;margin:22px 0 0">{{ t.hero.lead }}</p>

        <div style="display:flex;flex-wrap:wrap;gap:14px;margin-top:30px">
          <button data-open-modal style="background:#C83E34;color:#fff;border:none;padding:16px 30px;border-radius:999px;font-family:'Manrope';font-weight:800;font-size:17px;cursor:pointer;display:inline-flex;align-items:center;gap:10px;box-shadow:0 12px 30px rgba(225,37,27,.4);animation:bbPulse 3.4s ease-in-out infinite">
            <span style="font-size:18px">♥</span>{{ t.hero.cta }}
          </button>
          <a href="#campagne" style="background:transparent;color:#0E3F51;border:1.5px solid rgba(14,63,81,.3);padding:16px 28px;border-radius:999px;font-weight:700;font-size:16px;cursor:pointer;text-decoration:none;display:inline-flex;align-items:center;gap:8px">{{ t.hero.cta2 }}</a>
        </div>

        <div style="display:flex;gap:26px;margin-top:34px;flex-wrap:wrap">
          <div style="display:flex;align-items:center;gap:11px">
            <span style="width:38px;height:38px;border-radius:10px;background:rgba(225,37,27,.16);display:flex;align-items:center;justify-content:center;color:#C83E34;font-size:17px">▦</span>
            <div><div style="font-size:12px;color:#8a8d7e;font-weight:700;text-transform:uppercase;letter-spacing:.6px">{{ t.hero.dateLabel }}</div><div style="font-weight:800;font-size:15px">{{ t.hero.date }}</div></div>
          </div>
          <div style="display:flex;align-items:center;gap:11px">
            <span style="width:38px;height:38px;border-radius:10px;background:rgba(58,133,86,.18);display:flex;align-items:center;justify-content:center;color:#6BA480;font-size:17px">⚲</span>
            <div><div style="font-size:12px;color:#8a8d7e;font-weight:700;text-transform:uppercase;letter-spacing:.6px">{{ t.hero.placeLabel }}</div><div style="font-weight:800;font-size:15px">{{ t.hero.place }}</div></div>
          </div>
        </div>
      </div>

      <div style="position:relative;display:flex;flex-direction:column;align-items:center;gap:22px">
        <img src="{{ asset('assets/head.png') }}" alt="2 ans" style="width:40%;max-width:430px;filter:drop-shadow(0 18px 40px rgba(0,0,0,.4));animation:bbFloat 8s ease-in-out infinite"/>
        <img src="{{ asset('assets/logo-2ans.png') }}" alt="2 ans" style="width:88%;max-width:430px;filter:drop-shadow(0 18px 40px rgba(0,0,0,.4));animation:bbFloat 8s ease-in-out infinite"/>
        <div style="display:inline-flex;flex-wrap:wrap;align-items:center;gap:13px;background:#fff;color:#14160F;padding:13px 20px 13px 14px;border-radius:16px;box-shadow:0 16px 40px rgba(0,0,0,.35);max-width:100%">
          <span style="width:42px;height:50px;display:flex;align-items:center;justify-content:center;position:relative;flex:none">
            <span style="position:absolute;inset:0;background:#C83E34;border-radius:50% 50% 50% 50%/60% 60% 40% 40%;transform:rotate(45deg);clip-path:polygon(50% 0,100% 100%,0 100%);border-radius:0 50% 50% 50%"></span>
            <span style="position:relative;color:#fff;font-size:16px;z-index:1">♥</span>
          </span>
          <div>
            <div style="font-family:'Anton';font-size:clamp(17px,3vw,20px);line-height:1;letter-spacing:.5px;text-transform:uppercase">Sang Donné, Vies Sauvées</div>
            <div style="font-size:12.5px;color:#6a6a60;font-weight:700;margin-top:3px">{{ t.hero.edition }}</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ STATS 2 ANS ============ -->
  <section style="background:#0E3F51;color:#fff;padding:clamp(40px,7vw,64px) clamp(16px,5vw,24px)">
    <div style="max-width:1100px;margin:0 auto;display:grid;grid-template-columns:repeat(auto-fit,minmax(320px,1fr));gap:clamp(28px,5vw,56px);align-items:center">
      <div>
        <div style="color:#89B69A;font-weight:800;font-size:13px;letter-spacing:2px;text-transform:uppercase">{{ t.stats.kicker }}</div>
        <h2 style="font-family:'Anton';font-size:clamp(28px,5.5vw,40px);line-height:1.08;text-transform:uppercase;margin:12px 0 0">{{ t.stats.title }}</h2>
        <p style="font-size:clamp(14.5px,2vw,16px);line-height:1.6;color:rgba(255,255,255,.78);margin:16px 0 0;max-width:460px">{{ t.stats.lead }}</p>
        <div style="display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:26px;margin-top:34px;max-width:380px">
          {% for stat in t.statsList %}
            <div>
              <div style="font-family:'Anton';font-size:clamp(28px,5vw,40px);line-height:1;color:#fff">{{ stat.n }}</div>
              <div style="font-size:13px;font-weight:700;color:#9fb3bc;margin-top:7px;text-transform:uppercase;letter-spacing:.4px">{{ stat.l }}</div>
            </div>
          {% endfor %}
        </div>
      </div>
      <div style="position:relative;display:flex;justify-content:center;align-items:center;min-height:240px">
        <div style="position:absolute;width:240px;height:240px;border-radius:50%;background:radial-gradient(circle,rgba(58,133,86,.35),transparent 70%);filter:blur(6px)"></div>
        <img src="{{ asset('assets/mark-coureur.png') }}" alt="Bénin Bouge" style="position:relative;width:72%;max-width:280px;filter:drop-shadow(0 18px 40px rgba(0,0,0,.35));animation:bbFloat 8s ease-in-out infinite"/>
      </div>
    </div>
  </section>

  <!-- ============ VOEUX D'ANNIVERSAIRE ============ -->
  <section id="voeux" style="background:#0E3F51;color:#fff;padding:clamp(44px,8vw,78px) clamp(16px,5vw,24px)">
    <div style="max-width:900px;margin:0 auto">
      <div style="text-align:center;margin-bottom:30px">
        <div style="color:#89B69A;font-weight:800;font-size:13px;letter-spacing:2px;text-transform:uppercase;opacity:.85">{{ t.voeux.kicker }}</div>
        <h2 style="font-family:'Anton';font-size:clamp(26px,5.5vw,40px);margin:12px 0 0;text-transform:uppercase">{{ t.voeux.title }}</h2>
        <p style="font-size:clamp(15px,2.2vw,16.5px);line-height:1.6;color:rgba(255,255,255,.85);margin:14px auto 0;max-width:560px">{{ t.voeux.lead }}</p>
      </div>

      {% for msg in app.flashes('voeu_success') %}
        <div style="background:#fff;color:#0E3F51;border-radius:12px;padding:14px 18px;margin-bottom:18px;font-weight:700;text-align:center">✓ {{ msg }}</div>
      {% endfor %}
      {% for msg in app.flashes('voeu_error') %}
        <div style="background:#fdeaea;color:#b91c1c;border-radius:12px;padding:14px 18px;margin-bottom:18px;font-weight:700;text-align:center">{{ msg }}</div>
      {% endfor %}

      <form method="post" action="{{ path('messages_create') }}" style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);border-radius:18px;padding:clamp(18px,4vw,26px);display:flex;flex-direction:column;gap:12px">
        <input type="hidden" name="lang" value="{{ lang }}">
        <input name="author_name" maxlength="80" required placeholder="{{ t.voeux.namePh }}" style="background:#fff;border:none;border-radius:11px;padding:13px 15px;font-family:'Manrope';font-size:15px;outline:none;color:#14160F">
        <textarea name="message" maxlength="500" required placeholder="{{ t.voeux.messagePh }}" rows="3" style="background:#fff;border:none;border-radius:11px;padding:13px 15px;font-family:'Manrope';font-size:15px;outline:none;color:#14160F;resize:vertical"></textarea>
        <button type="submit" style="align-self:flex-start;background:#C83E34;color:#fff;border:none;padding:13px 26px;border-radius:999px;font-family:'Manrope';font-weight:800;font-size:15px;cursor:pointer">{{ t.voeux.submit }}</button>
      </form>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:14px;margin-top:30px">
        {% for msg in birthdayMessages %}
          <div style="background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.16);border-radius:14px;padding:18px;min-width:0">
            <div style="font-size:14.5px;line-height:1.5;overflow-wrap:break-word">"{{ msg.message }}"</div>
            <div style="margin-top:10px;font-weight:800;font-size:13px;color:#9fb3bc">— {{ msg.authorName }}</div>
          </div>
        {% else %}
          <p style="color:rgba(255,255,255,.75);grid-column:1/-1;text-align:center">{{ t.voeux.empty }}</p>
        {% endfor %}
      </div>

      <div style="text-align:center;margin-top:24px">
        <a href="{{ path('messages_list', {lang: lang}) }}" style="color:#fff;text-decoration:none;font-weight:800;font-size:14px;border-bottom:2px solid rgba(255,255,255,.5);padding-bottom:2px">{{ t.voeux.seeAll }} →</a>
      </div>
    </div>
  </section>

  <!-- ============ CAMPAGNE ============ -->
  <section id="campagne" style="background:#FBF7EC;padding:clamp(48px,8vw,84px) clamp(16px,5vw,24px)">

    <!-- intro : présentation de la campagne + objectif + logo -->
    <div style="max-width:1000px;margin:0 auto;display:flex;align-items:center;gap:clamp(32px,5vw,64px);flex-wrap:wrap">
      <div style="flex:1;min-width:280px">
        <div style="display:inline-flex;align-items:center;gap:9px;background:#C83E34;color:#fff;padding:7px 15px;border-radius:999px;font-weight:800;font-size:13px;letter-spacing:1.5px;text-transform:uppercase">
          <span style="width:7px;height:7px;background:#fff;border-radius:50%;display:inline-block"></span>{{ t.campIntro.kicker }}
        </div>
        <h2 style="font-family:'Anton';font-size:clamp(32px,6vw,54px);line-height:1.02;margin:16px 0 0;text-transform:uppercase;color:#0E3F51">{{ t.campIntro.title }}</h2>
        <p style="font-size:clamp(15px,2.2vw,17.5px);line-height:1.65;color:#54544c;margin:16px 0 0">{{ t.campIntro.lead }}</p>
        <div style="display:inline-flex;flex-wrap:wrap;align-items:center;gap:24px;background:#fff;border:2px solid rgba(225,37,27,.22);border-radius:20px;padding:20px 28px;margin-top:28px;box-shadow:0 8px 28px rgba(225,37,27,.1)">
          <div>
            <div style="font-family:'Anton';font-size:clamp(40px,8vw,64px);color:#C83E34;line-height:1">{{ t.campIntro.goal }}</div>
            <div style="font-size:12.5px;font-weight:800;color:#6a6a60;text-transform:uppercase;letter-spacing:.5px;margin-top:5px">{{ t.campIntro.goalLabel }}</div>
          </div>
          <div style="width:1px;height:56px;background:#ece9dd;flex:none"></div>
          <div style="font-size:14.5px;color:#54544c;line-height:1.55;max-width:190px">{{ t.campIntro.goalSub }}</div>
        </div>
      </div>
      <div style="flex:none;display:flex;justify-content:center;align-items:center">
        <img src="{{ asset('assets/logo-sdvs.png') }}" alt="Sang Donné, Vies Sauvées" style="width:clamp(180px,28vw,280px);filter:drop-shadow(0 14px 36px rgba(225,37,27,.22));animation:bbFloat 9s ease-in-out infinite"/>
      </div>
    </div>

    <div style="max-width:1100px;margin:clamp(48px,7vw,72px) auto 0;display:grid;grid-template-columns:repeat(auto-fit,minmax(300px,1fr));gap:clamp(28px,5vw,56px);align-items:center">
      <div style="position:relative">
        <div style="position:absolute;top:-14px;left:-14px;width:100%;height:100%;border:2px solid #3A8556;border-radius:20px;z-index:0"></div>
        <img src="{{ asset('assets/flyer-donneur.jpg') }}" alt="Et si vous deveniez donneur ?" style="position:relative;z-index:1;width:100%;border-radius:18px;box-shadow:0 22px 50px rgba(0,0,0,.14);display:block"/>
      </div>
      <div>
        <div style="color:#C83E34;font-weight:800;font-size:13px;letter-spacing:2px;text-transform:uppercase">{{ t.camp.kicker }}</div>
        <h2 style="font-family:'Anton';font-size:clamp(30px,6vw,46px);line-height:1.02;margin:14px 0 0;text-transform:uppercase;letter-spacing:.3px">{{ t.camp.title }}</h2>
        <p style="font-size:clamp(15px,2.2vw,17px);line-height:1.65;color:#54544c;margin:18px 0 0">{{ t.camp.lead }}</p>
        <div style="display:flex;flex-direction:column;gap:16px;margin-top:26px">
          {% for pt in t.campPoints %}
            <div style="display:flex;gap:14px;align-items:flex-start">
              <span style="flex:none;width:34px;height:34px;border-radius:9px;background:#fdeaea;color:#C83E34;display:flex;align-items:center;justify-content:center;font-size:16px;font-weight:800">{{ pt.icon }}</span>
              <div>
                <div style="font-weight:800;font-size:16px">{{ pt.t }}</div>
                <div style="font-size:14.5px;color:#6a6a60;line-height:1.55;margin-top:2px">{{ pt.d }}</div>
              </div>
            </div>
          {% endfor %}
        </div>
        <button data-open-modal style="margin-top:30px;background:#0E3F51;color:#fff;border:none;padding:15px 28px;border-radius:999px;font-family:'Manrope';font-weight:800;font-size:16px;cursor:pointer;display:inline-flex;align-items:center;gap:9px">
          <span style="color:#C83E34">♥</span>{{ t.camp.cta }}
        </button>
      </div>
    </div>
  </section>

  <!-- ============ BLOC DON ============ -->
  <section id="don" style="background:#C83E34;color:#fff;padding:clamp(48px,8vw,84px) clamp(16px,5vw,24px);position:relative;overflow:hidden">
    <div style="position:absolute;top:10%;left:8%;font-size:22px;color:rgba(255,255,255,.3);animation:bbSpark 4s ease-in-out infinite">✦</div>
    <div style="position:absolute;bottom:14%;right:10%;width:30px;height:6px;background:rgba(255,255,255,.25);border-radius:4px;transform:rotate(-20deg)"></div>
    <div style="max-width:760px;margin:0 auto;text-align:center;position:relative">
      <div style="color:#fff;font-weight:800;font-size:13px;letter-spacing:2px;text-transform:uppercase">{{ t.give.kicker }}</div>
      <h2 style="font-family:'Anton';font-size:clamp(28px,6vw,48px);line-height:1.02;margin:14px 0 0;text-transform:uppercase">{{ t.give.title }}</h2>
      <p style="font-size:clamp(15px,2.2vw,17px);line-height:1.6;color:rgba(255,255,255,.85);margin:16px auto 0;max-width:560px">{{ t.give.lead }}</p>

      <div style="background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.16);border-radius:22px;padding:clamp(18px,5vw,30px);margin-top:38px;text-align:left">
        <div style="font-size:13px;font-weight:800;color:#fff;text-transform:uppercase;letter-spacing:1px;margin-bottom:14px">{{ t.give.choose }}</div>
        <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:12px" data-chip-group data-style="dark">
          {% for v in chipAmounts %}
            <button type="button" data-chip data-amount="{{ v }}" style="display:flex;align-items:baseline;justify-content:center;background:rgba(255,255,255,.06);border:1.5px solid rgba(255,255,255,.18);color:#fff;border-radius:14px;padding:16px 4px;cursor:pointer;transition:all .15s">
              <span style="font-family:'Anton';font-size:clamp(17px,4vw,24px);line-height:1">{{ v|number_format(0, ',', ' ') }}</span>
              <span style="font-size:11px;font-weight:700;opacity:.7;margin-left:3px">FCFA</span>
            </button>
          {% endfor %}
          <div style="grid-column:span 3;display:flex;align-items:center;gap:12px;background:rgba(255,255,255,.07);border:1px solid rgba(255,255,255,.16);border-radius:14px;padding:4px 16px;margin-top:2px">
            <span style="color:#fff;font-weight:700;font-size:14px">{{ t.give.free }}</span>
            <input data-custom-amount inputmode="numeric" placeholder="{{ t.give.freePh }}" style="flex:1;min-width:0;background:transparent;border:none;outline:none;color:#fff;font-family:'Anton';font-size:22px;padding:12px 0"/>
            <span style="color:#fff;font-weight:800;font-size:14px">FCFA</span>
          </div>
        </div>
