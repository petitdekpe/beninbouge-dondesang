  <!-- ============ TUNNEL DE DON (MODAL) ============ -->
  <div id="donation-modal" style="display:none;position:fixed;inset:0;z-index:90;background:rgba(8,9,6,.62);backdrop-filter:blur(4px);align-items:flex-start;justify-content:center;padding:clamp(16px,5vw,32px) clamp(10px,4vw,18px);overflow-y:auto">
    <div data-modal-card style="width:100%;max-width:480px;background:#fff;border-radius:22px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.4);animation:bbRise .3s ease">
      <!-- header -->
      <div style="background:#295D3C;color:#fff;padding:18px 22px;display:flex;align-items:center;justify-content:space-between">
        <div style="display:flex;align-items:center;gap:10px">
          <span style="width:30px;height:30px;border-radius:8px;background:#C83E34;display:flex;align-items:center;justify-content:center;font-size:15px">♥</span>
          <div style="font-weight:800;font-size:15px">{{ t.m.title }}</div>
        </div>
        <button type="button" data-close-modal style="background:rgba(255,255,255,.12);border:none;color:#fff;width:30px;height:30px;border-radius:8px;cursor:pointer;font-size:16px;line-height:1">✕</button>
      </div>
      <!-- progress -->
      <div style="height:4px;background:#eee"><div data-progress-bar style="height:100%;background:#C83E34;width:33%;transition:width .3s"></div></div>
      <div style="display:flex;justify-content:space-between;padding:14px 22px 0;font-size:11px;font-weight:800;color:#bdbdb4;text-transform:uppercase;letter-spacing:.5px">
        <span data-step-tab="1" style="color:#C83E34">1 · {{ t.m.step1 }}</span>
        <span data-step-tab="2">2 · {{ t.m.step2 }}</span>
        <span data-step-tab="3">3 · {{ t.m.step3 }}</span>
      </div>

      <div style="padding:clamp(16px,4vw,22px)">
        <!-- STEP 1: MONTANT -->
        <div data-step-panel="1">
          <div style="font-family:'Anton';font-size:22px;text-transform:uppercase">{{ t.m.amountTitle }}</div>
          <div style="display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:10px;margin-top:16px" data-chip-group data-style="light">
            {% for v in chipAmounts %}
              <button type="button" data-chip data-amount="{{ v }}" style="display:flex;align-items:center;justify-content:center;background:#f6f5ef;border:1.5px solid #e6e3d7;color:#14160F;border-radius:12px;padding:14px 4px;cursor:pointer;transition:all .15s">
                <span style="font-family:'Anton';font-size:clamp(15px,4vw,19px)">{{ v|number_format(0, ',', ' ') }}</span>
              </button>
            {% endfor %}
            <div style="grid-column:span 3;display:flex;align-items:center;gap:10px;background:#f6f5ef;border:1px solid #e6e3d7;border-radius:12px;padding:2px 14px">
              <span style="color:#fff;font-weight:700;font-size:13px">{{ t.give.free }}</span>
              <input data-custom-amount inputmode="numeric" placeholder="{{ t.give.freePh }}" style="flex:1;min-width:0;background:transparent;border:none;outline:none;color:#14160F;font-family:'Anton';font-size:19px;padding:12px 0"/>
              <span style="color:#fff;font-weight:800;font-size:13px">FCFA</span>
            </div>
          </div>
          <button type="button" data-next style="width:100%;margin-top:20px;background:#C83E34;color:#fff;border:none;padding:15px;border-radius:12px;font-family:'Manrope';font-weight:800;font-size:16px;cursor:pointer">{{ t.m.continue }} · <span data-amount-label>{{ '5000'|number_format(0, ',', ' ') }}</span> FCFA</button>
        </div>

        <!-- STEP 2: COORDONNÉES -->
        <div data-step-panel="2" hidden>
          <div style="font-family:'Anton';font-size:22px;text-transform:uppercase">{{ t.m.infoTitle }}</div>
          <div style="display:flex;flex-direction:column;gap:12px;margin-top:16px">
            <div>
              <label style="font-size:12.5px;font-weight:700;color:#6a6a60">{{ t.m.nameLabel }}</label>
              <input data-field="name" placeholder="{{ t.m.namePh }}" style="width:100%;margin-top:6px;background:#f6f5ef;border:1px solid #e6e3d7;border-radius:11px;padding:13px 15px;font-family:'Manrope';font-size:15px;outline:none;color:#14160F"/>
            </div>
            <div>
              <label style="font-size:12.5px;font-weight:700;color:#6a6a60">{{ t.m.emailLabel }}</label>
              <input data-field="email" type="email" placeholder="{{ t.m.emailPh }}" style="width:100%;margin-top:6px;background:#f6f5ef;border:1px solid #e6e3d7;border-radius:11px;padding:13px 15px;font-family:'Manrope';font-size:15px;outline:none;color:#14160F"/>
            </div>
            <label style="display:flex;align-items:center;gap:10px;cursor:pointer;font-size:14px;color:#54544c;margin-top:2px">
              <button type="button" data-toggle-anon style="flex:none;width:22px;height:22px;border-radius:6px;border:2px solid #cfcdc2;background:#fff;color:#fff;cursor:pointer;font-size:13px;font-weight:800;display:flex;align-items:center;justify-content:center;padding:0"></button>{{ t.m.anon }}
            </label>
          </div>
          <div style="display:flex;gap:10px;margin-top:20px">
            <button type="button" data-back style="flex:none;background:#f0efe8;color:#14160F;border:none;padding:15px 20px;border-radius:12px;font-weight:800;font-size:15px;cursor:pointer">← {{ t.m.back }}</button>
            <button type="button" data-next disabled style="flex:1;background:#e9c4c2;color:#fff;border:none;padding:15px;border-radius:12px;font-family:Manrope;font-weight:800;font-size:16px;cursor:not-allowed">{{ t.m.continue }}</button>
          </div>
        </div>

        <!-- STEP 3: PAIEMENT -->
        <div data-step-panel="3" hidden>
          <div style="background:#f6f5ef;border-radius:13px;padding:14px 16px;display:flex;align-items:center;justify-content:space-between;margin-bottom:18px">
            <span style="font-size:14px;color:#6a6a60;font-weight:600">{{ t.m.youGive }}</span>
            <span style="font-family:'Anton';font-size:24px;color:#C83E34"><span data-amount-label>{{ '5000'|number_format(0, ',', ' ') }}</span> <span style="font-size:14px;color:#14160F">FCFA</span></span>
          </div>
          <div style="font-family:'Anton';font-size:20px;text-transform:uppercase">{{ t.m.payTitle }}</div>
          <div style="display:flex;flex-direction:column;gap:10px;margin-top:14px" data-method-group>
            {% for m in methods %}
              <button type="button" data-method data-method-id="{{ m.id }}" style="display:flex;align-items:center;gap:13px;background:#fff;border:1.5px solid #e6e3d7;border-radius:13px;padding:13px 15px;cursor:pointer;width:100%">
                <span style="flex:none;width:40px;height:30px;border-radius:7px;background:{{ m.color }};color:{{ m.ink }};display:flex;align-items:center;justify-content:center;font-weight:800;font-size:13px;font-family:Manrope">{{ m.abbr }}</span>
                <span style="font-weight:800;font-size:15px;flex:1;text-align:left">{{ m.name }}</span>
                <span data-method-radio style="flex:none;width:20px;height:20px;border-radius:50%;border:2px solid #cfcdc2;background:transparent"></span>
              </button>
            {% endfor %}
          </div>
          <div style="display:flex;gap:10px;margin-top:20px">
            <button type="button" data-back style="flex:none;background:#f0efe8;color:#14160F;border:none;padding:15px 20px;border-radius:12px;font-weight:800;font-size:15px;cursor:pointer">←</button>
            <button type="button" data-pay style="flex:1;background:#C83E34;color:#fff;border:none;padding:15px;border-radius:12px;font-family:'Manrope';font-weight:800;font-size:16px;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:9px">{{ t.m.payNow }} · <span data-amount-label>{{ '5000'|number_format(0, ',', ' ') }}</span> FCFA</button>
          </div>
          <div data-pay-error hidden style="margin-top:14px;background:#fdeaea;color:#b91c1c;border-radius:10px;padding:11px 14px;font-size:13px;font-weight:700;text-align:center"></div>
          <div style="display:flex;align-items:center;justify-content:center;gap:8px;margin-top:16px;color:#fff;font-size:12.5px;font-weight:600">
            <span style="color:#6BA480">🔒</span>{{ t.m.fedaSecured }}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- ============ PROMO MODAL: BAOBAB EXPRESS X BÉNIN BOUGE ============ -->
  <div id="baobab-promo-modal" style="display:none;position:fixed;inset:0;z-index:95;background:rgba(8,9,6,.7);backdrop-filter:blur(4px);align-items:center;justify-content:center;padding:clamp(16px,5vw,32px)">
    <div style="position:relative;width:100%;max-width:420px;animation:bbRise .35s ease">
      <button type="button" id="baobab-promo-close" aria-label="Fermer" style="position:absolute;top:-14px;right:-14px;width:36px;height:36px;border-radius:50%;background:#fff;border:none;box-shadow:0 6px 18px rgba(0,0,0,.3);cursor:pointer;font-size:16px;line-height:1;font-weight:800;color:#14160F;z-index:2">✕</button>
      <div style="background:#fff;border-radius:20px;overflow:hidden;box-shadow:0 30px 80px rgba(0,0,0,.45)">
        <a href="{{ path('baobab') }}" style="display:block">
          <img src="{{ asset('assets/baobabxbeninboouge.jpeg') }}" alt="Baobab Express x Bénin Bouge — Transport gratuit" style="width:100%;height:auto;display:block"/>
        </a>
        <div style="padding:18px">
          <a href="{{ path('baobab') }}" style="display:block;text-align:center;background:#C83E34;color:#fff;text-decoration:none;padding:15px;border-radius:12px;font-family:'Manrope';font-weight:800;font-size:16px;box-shadow:0 12px 30px rgba(200,62,52,.35)">Je réserve mon ticket GRATUIT</a>
        </div>
      </div>
    </div>
  </div>

</div>
{% endblock %}

{% block javascripts %}
<script src="https://cdn.fedapay.com/checkout.js?v=1.1.7"></script>
<script>
  window.BB_CONFIG = {
    fedapayPublicKey: {{ fedapayPublicKey|json_encode|raw }},
    lang: {{ lang|json_encode|raw }},
    isAnonymousLabel: {{ t.m.anon|json_encode|raw }},
    loadErrorMessage: {{ (lang == 'fr' ? 'Le module de paiement n’a pas pu se charger. Vérifiez votre connexion et réessayez.' : 'The payment module failed to load. Check your connection and try again.')|json_encode|raw }},
    processingLabel: {{ (lang == 'fr' ? 'Traitement…' : 'Processing…')|json_encode|raw }},
    payLabel: {{ t.m.payNow|json_encode|raw }},
    donorFallback: {{ (lang == 'fr' ? 'Donateur' : 'Donor')|json_encode|raw }},
    merciUrl: {{ path('merci')|json_encode|raw }}
  };
</script>
<script src="{{ asset('js/donation.js') }}"></script>
<script>
(function () {
  var modal = document.getElementById('baobab-promo-modal');
  if (!modal) return;

  var DISMISS_KEY = 'bb_baobab_promo_dismissed';
  var alreadyDismissed = false;
  try { alreadyDismissed = sessionStorage.getItem(DISMISS_KEY) === '1'; } catch (e) {}

  function closePromo() {
    modal.style.display = 'none';
    try { sessionStorage.setItem(DISMISS_KEY, '1'); } catch (e) {}
  }

  if (!alreadyDismissed) {
    modal.style.display = 'flex';
  }

  var closeBtn = document.getElementById('baobab-promo-close');
  if (closeBtn) closeBtn.addEventListener('click', function (e) { e.preventDefault(); closePromo(); });

  modal.addEventListener('click', function (e) {
    if (e.target === modal) closePromo();
  });
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && modal.style.display !== 'none') closePromo();
  });
})();
</script>
{% endblock %}
